# Public HTTPS URL of the llama.cpp server (typically a Cloudflare Tunnel
# pointing at the phone's local llama.cpp HTTP server).
LLAMA_URL=https://your-tunnel.trycloudflare.com

# Model name passed to the OpenAI-compatible /v1/chat/completions endpoint.
# llama.cpp usually accepts any string here.
MODEL=gemma

# Port. Heroku injects $PORT automatically; only set for local dev.
PORT=3000
